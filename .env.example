# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# --- Host (npm run …): DB path on your machine
# DATABASE_URL="file:$HOME/.nsecbunker-config/nsecbunker.db"
# --- Docker Compose: DB is under the mounted /app/config volume
DATABASE_URL="file:/app/config/nsecbunker.db"

# Admin npub(s), comma-separated (merged on start)
# ADMIN_NPUBS=npub1q2s369...

# Name of the encrypted signing key in nsecbunker.json (passphrase via signer-identity.txt → Docker secret)
NSECBUNKER_KEY_NAME=bitspark@local

# Docker: copy your passphrase file here (gitignored), same format as nsecbunkerd-local/signer-identity.txt
#   cp ../nsecbunkerd-local/signer-identity.txt ./signer-identity.txt
